{
  "info": {
    "_postman_id": "f1d87fc5-2afd-466a-994c-3714733530b9",
    "name": "sic-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53684816"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Cognito Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "if (pm.response.code === 200 && json.AuthenticationResult) {\r",
                  "  pm.environment.set(\"accessToken\", json.AuthenticationResult.AccessToken);\r",
                  "  pm.environment.set(\"idToken\", json.AuthenticationResult.IdToken);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-amz-json-1.1",
                "type": "text"
              },
              {
                "key": "X-Amz-Target",
                "value": "AWSCognitoIdentityProviderService.InitiateAuth",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"AuthFlow\": \"USER_PASSWORD_AUTH\",\r\n  \"ClientId\": \"{{userPoolClientId}}\",\r\n  \"AuthParameters\": {\r\n    \"USERNAME\": \"{{username}}\",\r\n    \"PASSWORD\": \"{{password}}\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://cognito-idp.{{region}}.amazonaws.com/",
              "protocol": "https",
              "host": [
                "cognito-idp",
                "{{region}}",
                "amazonaws",
                "com"
              ],
              "path": [
                ""
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "GET /sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions"
            },
            "description": "List sessions for the authenticated tenant. Uses bearer auth from {{accessToken}}."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Authenticated sessions list returns 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /sessions - no auth",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions"
            },
            "description": "Verify missing auth returns 401 Unauthorized."
          },
          "response": [],
          "auth": {
            "type": "noauth"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Missing auth returns 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /sessions/{sessionId}",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/{{sessionId}}"
            },
            "description": "Fetch a session by id. Set {{sessionId}} in the environment before running."
          },
          "response": []
        },
        {
          "name": "GET /sessions/{sessionId} - invalid id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sessions/00000000-0000-0000-0000-000000000000"
            },
            "description": "Invalid session id validation of 404 behavior."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Invalid session id returns 404\", function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /sessions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"sport\": \"soccer\",\r\n  \"ageBand\": \"u14\",\r\n  \"durationMin\": 45,\r\n  \"objectiveTags\": [\"pressing\"],\r\n  \"activities\": [\r\n    {\r\n      \"name\": \"Warm-up\",\r\n      \"description\": \"Dynamic movement prep\",\r\n      \"minutes\": 10\r\n    },\r\n    {\r\n      \"name\": \"Pressing game\",\r\n      \"description\": \"Small-sided pressing exercise\",\r\n      \"minutes\": 20\r\n    },\r\n    {\r\n      \"name\": \"Conditioned game\",\r\n      \"description\": \"Finish with an 8v8 conditioned game\",\r\n      \"minutes\": 15\r\n    }\r\n  ]\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/sessions"
            },
            "description": "Create a session with authenticated tenant context. Do not include tenant_id or tenantId in the request body."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Session creation returns 200 or 201\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{accessToken}}",
            "type": "string"
          }
        ]
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              ""
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "packages": {},
            "requests": {},
            "exec": [
              ""
            ]
          }
        }
      ]
    }
  ]
}
