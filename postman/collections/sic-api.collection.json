    {
      "name": "Session Packs",
      "item": [
        {
          "name": "POST /session-packs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status is 201\", function () {\r",
                  "  pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"response has pack\", function () {\r",
                  "  pm.expect(json).to.have.property(\"pack\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"pack has core fields\", function () {\r",
                  "  pm.expect(json.pack).to.have.property(\"packId\");\r",
                  "  pm.expect(json.pack).to.have.property(\"createdAt\");\r",
                  "  pm.expect(json.pack).to.have.property(\"sport\", \"soccer\");\r",
                  "  pm.expect(json.pack).to.have.property(\"ageBand\", \"u14\");\r",
                  "  pm.expect(json.pack).to.have.property(\"durationMin\", 60);\r",
                  "  pm.expect(json.pack).to.have.property(\"theme\", \"pressing\");\r",
                  "  pm.expect(json.pack).to.have.property(\"sessionsCount\", 3);\r",
                  "  pm.expect(json.pack).to.have.property(\"sessions\");\r",
                  "  pm.expect(json.pack.sessions).to.be.an(\"array\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"sport\": \"soccer\",\r\n  \"ageBand\": \"u14\",\r\n  \"durationMin\": 60,\r\n  \"theme\": \"pressing\",\r\n  \"sessionsCount\": 3\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/session-packs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "session-packs"
              ]
            }
          },
          "response": []
        },
        {
          "name": "POST /session-packs - invalid body",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status is 400\", function () {\r",
                  "  pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"error shape exists\", function () {\r",
                  "  pm.expect(json).to.have.property(\"error\");\r",
                  "  pm.expect(json.error).to.have.property(\"code\", \"platform.bad_request\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"unknown field is tenantId\", function () {\r",
                  "  pm.expect(json.error).to.have.property(\"details\");\r",
                  "  pm.expect(json.error.details).to.have.property(\"unknown\");\r",
                  "  pm.expect(json.error.details.unknown).to.include(\"tenantId\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"sport\": \"soccer\",\r\n  \"ageBand\": \"u14\",\r\n  \"durationMin\": 60,\r\n  \"theme\": \"pressing\",\r\n  \"sessionsCount\": 3,\r\n  \"tenantId\": \"should-not-be-here\"\r\n}",
              "options": {
