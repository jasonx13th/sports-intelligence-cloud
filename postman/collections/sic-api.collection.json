    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Cognito Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "if (pm.response.code === 200 && json.AuthenticationResult) {\r",
                  "  pm.environment.set(\"accessToken\", json.AuthenticationResult.AccessToken);\r",
                  "  pm.environment.set(\"idToken\", json.AuthenticationResult.IdToken);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-amz-json-1.1",
                "type": "text"
              },
              {
                "key": "X-Amz-Target",
                "value": "AWSCognitoIdentityProviderService.InitiateAuth",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"AuthFlow\": \"USER_PASSWORD_AUTH\",\r\n  \"ClientId\": \"{{userPoolClientId}}\",\r\n  \"AuthParameters\": {\r\n    \"USERNAME\": \"{{username}}\",\r\n    \"PASSWORD\": \"{{password}}\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://cognito-idp.{{region}}.amazonaws.com/",
              "protocol": "https",
              "host": [
                "cognito-idp",
                "{{region}}",
                "amazonaws",
                "com"
              ],
              "path": [
                ""
              ]
            }
          },
          "response": []
        }
      ]
    },
